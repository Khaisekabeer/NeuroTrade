# Neuro Trade — environment configuration
# Copy this file to .env and fill in your values.

# ─── Database ──────────────────────────────────────────────────────────
# SQLite (default — zero-config, good for single-host deployments)
DATABASE_URL=file:./db/custom.db
# For PostgreSQL (recommended for multi-instance / production scale):
# DATABASE_URL=postgresql://user:pass@localhost:5432/neurotrade

# ─── Trading Mode ──────────────────────────────────────────────────────
# PAPER (default) = simulated prices + in-memory execution (no real money)
# LIVE = real Bitget prices + real signed orders (REQUIRES Bitget API keys)
# Use the in-app PAPER/LIVE toggle to switch at runtime; this only sets the
# initial mode on boot.
INITIAL_MODE=paper

# ─── Bitget API (required for LIVE trading) ────────────────────────────
# Get these from https://www.bitget.com/api-doc/common/intro
# Start with DEMO keys (testnet) before going live with real funds!
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
# Set to 'true' to use Bitget's testnet (fake money, real API)
BITGET_DEMO=true

# ─── LLM Provider (for Sentiment + Orchestrator agents) ───────────────
# Three options — pick one. The sentiment agent fetches crypto news + LLM
# scores it; the orchestrator agent uses the LLM as a meta-reasoner.
#
# Option 1: z-ai (default, works in this sandbox, has rate limits)
#   (no env vars needed — leave LLM_PROVIDER unset or set to z-ai)
LLM_PROVIDER=z-ai
#
# Option 2: DeepSeek (FREE, open-source, no rate limits)
#   1. Get a free API key at https://platform.deepseek.com (gives $0.50 free credit)
#   2. Set:
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
#
# Option 3: OpenAI (paid, most reliable)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# Note: when using DeepSeek or OpenAI, news headlines are fetched from
# CryptoCompare's free news API (no key needed).

# ─── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
